<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soporte - Check Host</title>
    {{ importmap('app') }}
    <style>
        body { font-family: sans-serif; margin: 2rem; }
        input { padding: .5rem; width: 300px; }
        button { padding: .5rem 1rem; cursor: pointer; }
        table { border-collapse: collapse; margin-top: .5rem; }
        th, td { padding: .3rem .6rem; text-align: left; border: 1px solid #ccc; }
        th { background: #f5f5f5; }
        .region { margin-top: 1rem; padding: .8rem; border: 1px solid #ddd; border-radius: 4px; }
        .region h3 { margin: 0 0 .5rem; }
        .loading { display: none; color: #666; }
        .loading::after { content: '...'; animation: dots 1.5s steps(3) infinite; }
        @keyframes dots { 50% { content: '..'; } 75% { content: '.'; } }
    </style>
</head>
<body>
    <h1>Check Host</h1>

    <div {{ stimulus_controller('host-check') }}>
        <p>
            <input type="text" data-host-check-target="host" placeholder="IP o nombre DNS">
            <button data-action="host-check#check">Consultar</button>
        </p>

        <div data-host-check-target="statusResult"></div>
        <div class="loading" data-host-check-target="statusLoading">Verificando estado del host</div>

        <div class="region" data-host-check-target="homeDirsRegion" style="display:none">
            <h3>Directorios home</h3>
            <div class="loading" data-target="loading">Consultando directorios home</div>
            <div data-target="result"></div>
        </div>

        <div class="region" data-host-check-target="loggedUsersRegion" style="display:none">
            <h3>Usuarios Conectados</h3>
            <div class="loading" data-target="loading">Consultando usuarios conectados</div>
            <div data-target="result"></div>
        </div>
    </div>
</body>
</html>
